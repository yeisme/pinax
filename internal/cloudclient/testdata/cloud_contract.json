{
  "schema_version": "pinax.cloud.contract.mlp.v1",
  "terminology": "vault_id",
  "operations": [
    {
      "name": "health",
      "method": "GET",
      "path": "/v1/health",
      "success_status": 200,
      "success_body": {
        "status": "ok",
        "contract_version": "pinax.cloud.contract.mlp.v1"
      }
    },
    {
      "name": "bootstrap",
      "method": "POST",
      "path": "/v1/auth/bootstrap",
      "request_body": {
        "bootstrap_token": "<redacted>",
        "device_label": "dev_laptop"
      },
      "success_status": 200,
      "success_body": {
        "account_id": "acc_1",
        "device_id": "dev_laptop",
        "vault_id": "vault_1",
        "token_ref": "profile://cloud",
        "scope": "sync"
      }
    },
    {
      "name": "current_principal",
      "method": "GET",
      "path": "/v1/auth/principal",
      "headers": {
        "Authorization": "Bearer <redacted>",
        "X-Pinax-Device-ID": "dev_laptop"
      },
      "success_status": 200,
      "success_body": {
        "account_id": "acc_1",
        "device_id": "dev_laptop",
        "vault_id": "vault_1",
        "token_ref": "profile://cloud",
        "scope": "sync"
      }
    },
    {
      "name": "create_vault",
      "method": "POST",
      "path": "/v1/vaults",
      "request_body": {
        "crypto_mode": "client_encrypted_v1"
      },
      "success_status": 200,
      "success_body": {
        "vault_id": "vault_1",
        "crypto_mode": "client_encrypted_v1"
      }
    },
    {
      "name": "link_vault",
      "method": "POST",
      "path": "/v1/vaults/{vault_id}/link",
      "success_status": 200,
      "success_body": {
        "vault_id": "vault_1",
        "crypto_mode": "client_encrypted_v1"
      }
    },
    {
      "name": "changes",
      "method": "GET",
      "path": "/v1/vaults/{vault_id}/changes?since={revision_id}",
      "success_status": 200,
      "success_body": {
        "revisions": [
          {"revision_id": "rev_b", "manifest_blob_id": "blob_manifest"}
        ],
        "objects": [
          {"path_hash": "sha256:path", "blob_hash": "sha256:blob", "size": 42, "deleted": false}
        ],
        "has_more": false
      }
    },
    {
      "name": "current_head",
      "method": "GET",
      "path": "/v1/vaults/{vault_id}/head",
      "success_status": 200,
      "success_body": {
        "revision_id": "rev_a",
        "manifest_blob_id": "blob_manifest"
      }
    },
    {
      "name": "blob_batch_check",
      "method": "POST",
      "path": "/v1/vaults/{vault_id}/blobs:batch-check",
      "request_body": {
        "blob_ids": ["blob_a", "blob_b"]
      },
      "success_status": 200,
      "success_body": {
        "missing_blob_ids": ["blob_b"]
      }
    },
    {
      "name": "blob_sign_upload",
      "method": "POST",
      "path": "/v1/vaults/{vault_id}/blobs:sign-upload",
      "request_body": {
        "blob_id": "blob_b",
        "blob_hash": "sha256:blob_b",
        "size": 128,
        "content_type": "application/vnd.pinax.encrypted-envelope+json"
      },
      "success_status": 200,
      "success_body": {
        "blob_id": "blob_b",
        "object_key": "objects/00/00/example-server-owned.blob",
        "method": "PUT",
        "mode": "local-proxy",
        "url": "/v1/vaults/vault_1/blobs/blob_b",
        "expires_at": "2026-06-15T12:00:00Z"
      }
    },
    {
      "name": "blob_upload",
      "method": "PUT",
      "path": "/v1/vaults/{vault_id}/blobs/{blob_id}",
      "request_body": {
        "schema_version": "pinax.cloud.envelope.v1",
        "alg": "AES-256-GCM",
        "key_id": "key_1",
        "nonce": "base64-nonce",
        "ciphertext": "base64-ciphertext",
        "plain_sha256": "sha256-of-plaintext"
      },
      "success_status": 201,
      "success_body": {
        "blob_id": "blob_b"
      }
    },
    {
      "name": "blob_download",
      "method": "GET",
      "path": "/v1/vaults/{vault_id}/blobs/{blob_id}",
      "success_status": 200,
      "success_body": {
        "schema_version": "pinax.cloud.envelope.v1",
        "alg": "AES-256-GCM",
        "key_id": "key_1",
        "nonce": "base64-nonce",
        "ciphertext": "base64-ciphertext",
        "plain_sha256": "sha256-of-plaintext"
      }
    },
    {
      "name": "revision_commit",
      "method": "POST",
      "path": "/v1/vaults/{vault_id}/revisions",
      "headers": {
        "Authorization": "Bearer <redacted>",
        "X-Pinax-Device-ID": "dev_laptop",
        "Idempotency-Key": "req_123"
      },
      "request_body": {
        "base_revision": "rev_a",
        "revision_id": "rev_b",
        "manifest_blob_id": "blob_manifest",
        "object_refs": [
          {"path_hash": "sha256:path", "blob_id": "blob_a", "blob_hash": "sha256:blob_a", "size_bytes": 42, "deleted": false},
          {"path_hash": "sha256:path_2", "blob_id": "blob_b", "blob_hash": "sha256:blob_b", "size_bytes": 128, "deleted": false}
        ],
        "device_id": "dev_laptop"
      },
      "success_status": 200,
      "success_body": {
        "revision_id": "rev_b",
        "manifest_blob_id": "blob_manifest"
      }
    }
  ],
  "error_codes": [
    "UNAUTHENTICATED",
    "DEVICE_REVOKED",
    "FORBIDDEN_SCOPE",
    "REVISION_CONFLICT",
    "REVISION_NOT_FOUND",
    "VALIDATION_FAILED",
    "BLOB_MISSING",
    "BLOB_TOO_LARGE",
    "BLOB_HASH_MISMATCH",
    "BLOB_SIZE_MISMATCH",
    "UPLOAD_PLAN_EXPIRED",
    "BACKEND_UNAVAILABLE"
  ],
  "error_shape": {
    "error": {
      "code": "REVISION_CONFLICT",
      "message": "base revision is stale",
      "retryable": true
    }
  },
  "redaction_rules": [
    "Do not include plaintext note body in backend logs, events, fixtures, or errors.",
    "Do not include raw token, Authorization header value, Cookie, or provider payload in backend logs, events, fixtures, or errors.",
    "Object keys and metadata SHALL NOT contain plaintext note paths."
  ]
}
